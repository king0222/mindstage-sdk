{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Example: Basic Usage",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/examples/basic-usage.ts",
            "runtimeArgs": [
                "-r",
                "tsx/register"
            ],
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Example: Render from JSON",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/examples/render-from-json.ts",
            "runtimeArgs": [
                "-r",
                "tsx/register"
            ],
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug All Tests",
            "autoAttachChildProcesses": true,
            "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
            "args": [
                "run"
            ],
            "smartStep": true,
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ]
        }
    ]
}