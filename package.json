{
  "name": "mindstage-sdk",
  "version": "1.0.0",
  "description": "The professional, lightweight core mind map engine that powers MindStage.app",
  "main": "dist/index.js",
  "browser": "dist/mindstage-sdk.js",
  "unpkg": "dist/mindstage-sdk.min.js",
  "jsdelivr": "dist/mindstage-sdk.min.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "index.ts"
  ],
  "homepage": "https://www.mindstage.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/mindstage/sdk"
  },
  "bugs": {
    "url": "https://github.com/mindstage/sdk/issues"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc && npm run build:bundle",
    "build:bundle": "node build-bundle.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,mjs,json,md,html}\"",
    "format:check": "prettier --check \"**/*.{ts,js,mjs,json,md,html}\"",
    "serve:examples": "http-server -p 8080",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "mindstage",
    "mindmap",
    "mind-map",
    "rendering",
    "layout",
    "export"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "nanoid": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "http-server": "^14.1.1",
    "prettier": "^3.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}